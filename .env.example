# ============================================
# TITANIUM WARRIOR v3 — Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# IBKR Connection
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_MARGIN_ACCOUNT=YOUR_MARGIN_ACCOUNT_ID
IBKR_CASH_ACCOUNT=YOUR_CASH_ACCOUNT_ID

# Alpha Vantage API
ALPHA_VANTAGE_API_KEY=YOUR_API_KEY_HERE

# Telegram Notifications
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Engine Toggles (true/false)
ENABLE_FUTURES=true
ENABLE_OPTIONS=false
ENABLE_MOMO=false
ENABLE_CRYPTO=true

# Capital Allocation (must sum to 100)
FUTURES_ALLOCATION=45
OPTIONS_ALLOCATION=0
MOMO_ALLOCATION=25
CRYPTO_ALLOCATION=30

# Risk Settings
MAX_DAILY_RISK_PCT=8
MAX_SIMULTANEOUS_POSITIONS=3
KILL_SWITCH_PCT=12
INITIAL_CAPITAL=500

# Trading Mode
TRADING_MODE=paper
